					<호번호><![CDATA[1.]]></호번호>
					<호내용><![CDATA[1.  "국제선박"이란 국제항행(國際航行)을 하는 상선(商船)으로서 제4조에 따라 국제선박등록부에 등록된 선박을 말한다.]]>
					</호내용>
				</호>
				<호>
					<호번호><![CDATA[2.]]></호번호>
					<호내용><![CDATA[2.  "선원"이란 임금을 받을 목적으로 국제선박에서 근로하기 위하여 고용된 사람을 말한다.]]>
					</호내용>
				</호>
				<호>
					<호번호><![CDATA[3.]]></호번호>
					<호내용><![CDATA[3.  "외항운송사업자"란 「해운법」 제4조제1항에 따라 외항 정기 여객운송사업 또는 외항 부정기 여객운송사업의 면허를 받은 자와 같은 법 제24조제2항에 따라 외항 정기 화물운송사업 또는 외항 부정기 화물운송사업을 등록한 자를 말한다.]]>
					</호내용>
				</호>
				<호>
					<호번호><![CDATA[4.]]></호번호>
					<호내용><![CDATA[4.  삭제 <2019.1.15>]]>
					</호내용>
				</호>
