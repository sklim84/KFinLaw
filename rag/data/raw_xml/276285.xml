				<항번호><![CDATA[①]]></항번호>
				<항내용><![CDATA[① 임대인은 임차인이 임대차기간이 만료되기 6개월 전부터 1개월 전까지 사이에 계약갱신을 요구할 경우 정당한 사유 없이 거절하지 못한다. 다만, 다음 각 호의 어느 하나의 경우에는 그러하지 아니하다. <개정 2013.8.13>]]>
				</항내용>
				<호>
					<호번호><![CDATA[1.]]></호번호>
					<호내용><![CDATA[1.  임차인이 3기의 차임액에 해당하는 금액에 이르도록 차임을 연체한 사실이 있는 경우]]>
					</호내용>
				</호>
				<호>
					<호번호><![CDATA[2.]]></호번호>
					<호내용><![CDATA[2.  임차인이 거짓이나 그 밖의 부정한 방법으로 임차한 경우]]>
					</호내용>
				</호>
				<호>
					<호번호><![CDATA[3.]]></호번호>
					<호내용><![CDATA[3.  서로 합의하여 임대인이 임차인에게 상당한 보상을 제공한 경우]]>
					</호내용>
				</호>
				<호>
					<호번호><![CDATA[4.]]></호번호>
					<호내용><![CDATA[4.  임차인이 임대인의 동의 없이 목적 건물의 전부 또는 일부를 전대(轉貸)한 경우]]>
					</호내용>
				</호>
				<호>
					<호번호><![CDATA[5.]]></호번호>
					<호내용><![CDATA[5.  임차인이 임차한 건물의 전부 또는 일부를 고의나 중대한 과실로 파손한 경우]]>
					</호내용>
				</호>
				<호>
					<호번호><![CDATA[6.]]></호번호>
					<호내용><![CDATA[6.  임차한 건물의 전부 또는 일부가 멸실되어 임대차의 목적을 달성하지 못할 경우]]>
					</호내용>
				</호>
				<호>
					<호번호><![CDATA[7.]]></호번호>
					<호내용><![CDATA[7.  임대인이 다음 각 목의 어느 하나에 해당하는 사유로 목적 건물의 전부 또는 대부분을 철거하거나 재건축하기 위하여 목적 건물의 점유를 회복할 필요가 있는 경우]]>
					</호내용>
					<목>
						<목번호><![CDATA[가.]]></목번호>
						<목내용><![CDATA[가.  임대차계약 체결 당시 공사시기 및 소요기간 등을 포함한 철거 또는 재건축 계획을 임차인에게 구체적으로 고지하고 그 계획에 따르는 경우]]>						</목내용>
					</목>
					<목>
						<목번호><![CDATA[나.]]></목번호>
						<목내용><![CDATA[나.  건물이 노후ㆍ훼손 또는 일부 멸실되는 등 안전사고의 우려가 있는 경우]]>						</목내용>
					</목>
					<목>
						<목번호><![CDATA[다.]]></목번호>
						<목내용><![CDATA[다.  다른 법령에 따라 철거 또는 재건축이 이루어지는 경우]]>						</목내용>
					</목>
				</호>
				<호>
					<호번호><![CDATA[8.]]></호번호>
					<호내용><![CDATA[8.  그 밖에 임차인이 임차인으로서의 의무를 현저히 위반하거나 임대차를 계속하기 어려운 중대한 사유가 있는 경우]]>
					</호내용>
				</호>
			</항>
			<항>
				<항번호><![CDATA[②]]></항번호>
				<항내용><![CDATA[② 임차인의 계약갱신요구권은 최초의 임대차기간을 포함한 전체 임대차기간이 10년을 초과하지 아니하는 범위에서만 행사할 수 있다. <개정 2018.10.16>]]>
				</항내용>
			</항>
			<항>
				<항번호><![CDATA[③]]></항번호>
				<항내용><![CDATA[③ 갱신되는 임대차는 전 임대차와 동일한 조건으로 다시 계약된 것으로 본다. 다만, 차임과 보증금은 제11조에 따른 범위에서 증감할 수 있다.]]>
				</항내용>
			</항>
			<항>
				<항번호><![CDATA[④]]></항번호>
				<항내용><![CDATA[④ 임대인이 제1항의 기간 이내에 임차인에게 갱신 거절의 통지 또는 조건 변경의 통지를 하지 아니한 경우에는 그 기간이 만료된 때에 전 임대차와 동일한 조건으로 다시 임대차한 것으로 본다. 이 경우에 임대차의 존속기간은 1년으로 본다. <개정 2009.5.8>]]>
				</항내용>
			</항>
			<항>
				<항번호><![CDATA[⑤]]></항번호>
				<항내용><![CDATA[⑤ 제4항의 경우 임차인은 언제든지 임대인에게 계약해지의 통고를 할 수 있고, 임대인이 통고를 받은 날부터 3개월이 지나면 효력이 발생한다.]]>
				</항내용>
			</항>
