				<항번호><![CDATA[①]]></항번호>
				<항내용><![CDATA[① 연구원에는 원장 1명과 필요한 공무원을 둔다.]]>
				</항내용>
			</항>
			<항>
				<항번호><![CDATA[②]]></항번호>
				<항내용><![CDATA[② 원장은 보건ㆍ환경 분야에 관한 학식과 경험이 풍부한 사람 중에서 시ㆍ도지사가 임명한다.]]>
				</항내용>
			</항>
			<항>
				<항번호><![CDATA[③]]></항번호>
				<항내용><![CDATA[③ 원장은 관할 시ㆍ도지사의 명을 받아 연구원의 업무를 총괄하고 소속 공무원을 지휘ㆍ감독한다.]]>
				</항내용>
			</항>
