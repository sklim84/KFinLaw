			<항>
				<항번호><![CDATA[①]]></항번호>
				<항내용><![CDATA[①한국임업전문학교등에 학장 각 1인을 둔다. <개정 2003.2.24, 2007.3.27>]]>
				</항내용>
			</항>
			<항>
				<항번호><![CDATA[②]]></항번호>
				<항내용><![CDATA[②학장은 교무를 총괄하고, 소속 공무원을 지휘ㆍ감독하며, 학생을 지도하고, 학교를 대표한다. <개정 2003.2.24>]]>
				</항내용>
			</항>
			<항>
				<항번호><![CDATA[③]]></항번호>
				<항내용><![CDATA[③학장은 해양수산부장관 또는 산림청장의 제청으로 대통령이 임용한다. 다만, 산림청장이 학장을 제청할 경우에는 농림축산식품부장관을 거쳐야 한다. <개정 2003.2.24, 2007.3.27, 2008.2.29, 2013.3.23>]]>
				</항내용>
			</항>
			<항>
				<항번호><![CDATA[④]]></항번호>
				<항내용><![CDATA[④한국임업전문학교등의 각 학과에 학과장을 두되, 해당 학과의 교수ㆍ부교수 또는 조교수중에서 학장이 보한다. <개정 2003.2.24, 2007.3.27>]]>
				</항내용>
			</항>
<조문참고자료>
