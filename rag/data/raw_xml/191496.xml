			<항>
				<항번호><![CDATA[①]]></항번호>
				<항내용><![CDATA[①당사자, 증인, 감정인, 통역인 또는 번역인(이하 "증인등"이라 한다)의 일당은 법원이 상당하다고 인정하는 출석 또는 조사 및 이를 위한 여행에 필요한 일수에 따라 지급한다.]]>
				</항내용>
			</항>
			<항>
				<항번호><![CDATA[②]]></항번호>
				<항내용><![CDATA[②증인등의 일당은 매년 대법관회의에서 정한다.]]>
				</항내용>
			</항>
