					<호번호><![CDATA[1.]]></호번호>
					<호내용><![CDATA[1.  "기상산업"이란 기상 관련 상품을 제조ㆍ공급하거나 용역을 공급하는 산업을 말한다.]]>
					</호내용>
				</호>
				<호>
					<호번호><![CDATA[2.]]></호번호>
					<호내용><![CDATA[2.  "기상예보"란 기상현상에 관하여 관측된 결과를 바탕으로 미래의 기상상태를 예상하여 제공하는 것을 말한다.]]>
					</호내용>
				</호>
				<호>
					<호번호><![CDATA[3.]]></호번호>
					<호내용><![CDATA[3.  "기상감정(氣象鑑定)"이란 기상현상에 관하여 관측된 결과를 바탕으로 특정 지점의 기상현상을 추정하거나 그 기상현상이 특정 사건에 미친 영향의 정도 등을 판단하는 것을 말한다.]]>
					</호내용>
				</호>
				<호>
					<호번호><![CDATA[4.]]></호번호>
					<호내용><![CDATA[4.  "기상예보업"이란 일반ㆍ특정 수요자를 대상으로 기상예보를 하는 사업을 말한다.]]>
					</호내용>
				</호>
				<호>
					<호번호><![CDATA[5.]]></호번호>
					<호내용><![CDATA[5.  "기상감정업"이란 특정 수요자를 대상으로 기상감정을 제공하는 사업을 말한다.]]>
					</호내용>
				</호>
				<호>
					<호번호><![CDATA[6.]]></호번호>
					<호내용><![CDATA[6.  "기상컨설팅업"이란 기상정보를 분석ㆍ평가하여 경영활동에 관한  조언을 제공하는 사업을 말한다.]]>
					</호내용>
				</호>
				<호>
					<호번호><![CDATA[7.]]></호번호>
					<호내용><![CDATA[7.  "기상장비업"이란 기상측기를 제작ㆍ수입ㆍ설치하거나 수리하는 사업을 말한다.]]>
					</호내용>
				</호>
				<호>
					<호번호><![CDATA[8.]]></호번호>
					<호내용><![CDATA[8.  "기상예보사"란 기상예보 업무를 담당하는 사람으로서 제18조에 따라 기상청장으로부터 면허를 받은 사람을 말한다.]]>
					</호내용>
				</호>
				<호>
					<호번호><![CDATA[9.]]></호번호>
					<호내용><![CDATA[9.  "기상감정사"란 기상감정 업무를 담당하는 사람으로서 제18조에 따라 기상청장으로부터 면허를 받은 사람을 말한다.]]>
					</호내용>
				</호>
				<호>
					<호번호><![CDATA[10.]]></호번호>
