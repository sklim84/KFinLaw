					</호내용>
				</호>
				<호>
					<호번호><![CDATA[2.]]></호번호>
					<호내용><![CDATA[2.  피해자의 진술로 인하여 위원회 절차가 현저하게 지연될 우려가 있는 경우]]>
					</호내용>
				</호>
