					<호내용><![CDATA[1.  법 제8조제1항에 따른 기반시설 관리에 관한 기본계획(이하 "기본계획"이라 한다)에서 정하고 있는 총사업비를 100분의 10 범위에서 변경하는 경우]]>
					</호내용>
				</호>
				<호>
					<호번호><![CDATA[2.]]></호번호>
					<호내용><![CDATA[2.  법과 이 영의 개정 또는 다른 법령의 제정ㆍ개정ㆍ폐지에 따라 그 내용을 반영하기 위하여 변경하는 경우]]>
					</호내용>
				</호>
				<호>
					<호번호><![CDATA[3.]]></호번호>
