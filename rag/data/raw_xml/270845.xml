			<조문내용><![CDATA[제2조(정의) 이 법에서 사용하는 용어의 뜻은 다음과 같다. <개정 2014.11.19, 2017.4.18, 2017.7.26, 2020.12.29, 2025.4.22>]]>
</조문내용>
			<항>
				<호>
					<호번호><![CDATA[1.]]></호번호>
					<호내용><![CDATA[1.  "해양경비"란 해양경찰청장이 경비수역에서 해양주권의 수호를 목적으로 행하는 해양안보 및 해양치안의 확보, 해양수산자원 및 해양시설의 보호를 위한 경찰권의 행사를 말한다.]]>
					</호내용>
				</호>
				<호>
					<호번호><![CDATA[2.]]></호번호>
					<호내용><![CDATA[2.  "경비수역"이란 대한민국의 법령과 국제법에 따라 대한민국의 권리가 미치는 수역으로서 연안수역, 근해수역 및 원해수역을 말한다.]]>
					</호내용>
				</호>
				<호>
					<호번호><![CDATA[3.]]></호번호>
					<호내용><![CDATA[3.  "연안수역"이란 「영해 및 접속수역법」 제1조 및 제3조에 따른 영해 및 내수(「내수면어업법」 제2조제1호에 따른 내수면은 제외한다)를 말한다.]]>
					</호내용>
				</호>
				<호>
					<호번호><![CDATA[4.]]></호번호>
					<호내용><![CDATA[4.  "근해수역"이란 「영해 및 접속수역법」 제3조의2에 따른 접속수역을 말한다.]]>
					</호내용>
				</호>
				<호>
					<호번호><![CDATA[5.]]></호번호>
					<호내용><![CDATA[5.  "원해수역"이란 「해양수산발전 기본법」 제3조제1호에 따른 해양 중 연안수역과 근해수역을 제외한 수역을 말한다.]]>
					</호내용>
				</호>
				<호>
					<호번호><![CDATA[6.]]></호번호>
					<호내용><![CDATA[6.  "해양수산자원"이란 「해양수산발전 기본법」 제3조제2호에 따른 해양수산자원을 말한다.]]>
					</호내용>
				</호>
				<호>
					<호번호><![CDATA[7.]]></호번호>
					<호내용><![CDATA[7.  "해양시설"이란 「해양환경관리법」 제2조제17호에 따른 해양시설을 말한다.]]>
					</호내용>
				</호>
				<호>
					<호번호><![CDATA[8.]]></호번호>
					<호내용><![CDATA[8.  "경비세력"이란 해양경찰청장이 해양경비를 목적으로 투입하는 인력, 함정, 항공기 및 전기통신설비 등을 말한다.]]>
					</호내용>
				</호>
				<호>
					<호번호><![CDATA[9.]]></호번호>
					<호내용><![CDATA[9.  "해상검문검색"이란 해양경찰청장이 경비세력을 사용하여 경비수역에서 선박등을 대상으로 정선(停船) 요구, 승선(乘船), 질문, 사실 확인, 선체(船體) 수색이나 그 밖에 필요한 조치를 하는 것을 말한다.]]>
					</호내용>
				</호>
				<호>
					<호번호><![CDATA[10.]]></호번호>
					<호내용><![CDATA[10.  "선박등"이란 「선박법」 제1조의2제1항에 따른 선박(이하 "선박"이라 한다), 「수상레저안전법」 제2조제3호에 따른 수상레저기구, 「어선법」 제2조제1호에 따른 어선, 그 밖에 수상에서 사람이 탑승하여 이동 가능한 기구를 말한다.]]>
					</호내용>
				</호>
				<호>
					<호번호><![CDATA[11.]]></호번호>
					<호내용><![CDATA[11.  "임해 중요시설"이란 바다와 인접하고 있는 공공기관, 공항, 항만, 발전소, 조선소 및 저유소(貯油所) 등 국민경제의 기간(基幹)이 되는 주요 산업시설로서 대통령령으로 정하는 시설을 말한다.]]>
					</호내용>
				</호>
				<호>
					<호번호><![CDATA[12.]]></호번호>
					<호내용><![CDATA[12.  "해양경비정보"란 해양경비 활동에 필요한 경비수역 내의 정보로서 다음 각 목의 어느 하나에 해당하는 정보를 말한다.]]>
					</호내용>
					<목>
						<목번호><![CDATA[가.]]></목번호>
						<목내용><![CDATA[가.  경비수역 및 경비세력 등에 관한 정보]]>						</목내용>
					</목>
					<목>
						<목번호><![CDATA[나.]]></목번호>
						<목내용><![CDATA[나.  선박등의 운항 및 보안ㆍ안전에 관한 정보(선박등의 위치, 입항ㆍ출항, 승선원 및 화물 등의 정보를 포함한다)]]>						</목내용>
					</목>
					<목>
						<목번호><![CDATA[다.]]></목번호>
						<목내용><![CDATA[다.  해양시설, 임해 중요시설 등의 보안ㆍ안전에 관한 정보]]>						</목내용>
					</목>
					<목>
						<목번호><![CDATA[라.]]></목번호>
						<목내용><![CDATA[라.  해양에서 수집한 영상ㆍ음성ㆍ음향ㆍ전기통신데이터 또는 이들의 조합으로 처리ㆍ가공ㆍ활용된 정보]]>						</목내용>
					</목>
					<목>
						<목번호><![CDATA[마.]]></목번호>
						<목내용><![CDATA[마.  수심ㆍ조류(潮流)ㆍ해양기상 등 해양 특성과 해저자원, 해양수산자원 등에 관한 정보]]>						</목내용>
					</목>
					<목>
						<목번호><![CDATA[바.]]></목번호>
						<목내용><![CDATA[바.  그 밖에 대통령령으로 정하는 정보]]>						</목내용>
					</목>
					<목>
						<목번호><![CDATA[사.]]></목번호>
						<목내용><![CDATA[사.  가목부터 바목까지의 정보를 결합ㆍ융합ㆍ분석ㆍ가공하여 생성된 정보]]>						</목내용>
					</목>
				</호>
