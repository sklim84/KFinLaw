			<조문내용><![CDATA[제13조(자위소방대의 임무) 자위소방대의 대장ㆍ부대장과 각 반의 임무는 다음 각 호와 같다.]]>
</조문내용>
			<항>
				<호>
					<호번호><![CDATA[1.]]></호번호>
					<호내용><![CDATA[1.  대장은 자위소방대를 총괄ㆍ지휘ㆍ운용한다.]]>
					</호내용>
				</호>
				<호>
					<호번호><![CDATA[2.]]></호번호>
					<호내용><![CDATA[2.  부대장은 대장을 보좌하고, 대장이 부득이한 사유로 임무를 수행할 수 없을 때에는 그 임무를 대행한다.]]>
					</호내용>
				</호>
				<호>
					<호번호><![CDATA[3.]]></호번호>
					<호내용><![CDATA[3.  지휘반은 대장의 지휘를 받아 다른 반의 임무를 조정하고, 화재진압 등에 관한 훈련계획을 수립ㆍ시행한다.]]>
					</호내용>
				</호>
				<호>
					<호번호><![CDATA[4.]]></호번호>
					<호내용><![CDATA[4.  진압반은 대장과 지휘반의 지휘를 받아 화재를 진압한다.]]>
					</호내용>
				</호>
				<호>
					<호번호><![CDATA[5.]]></호번호>
					<호내용><![CDATA[5.  구조구급반은 대장과 지휘반의 지휘를 받아 인명을 구조하고 부상자를 응급처치한다.]]>
					</호내용>
				</호>
				<호>
					<호번호><![CDATA[6.]]></호번호>
					<호내용><![CDATA[6.  대피유도반은 대장과 지휘반의 지휘를 받아 근무자 등을 안전한 장소로 대피하도록 유도한다.]]>
					</호내용>
				</호>
			</항>
