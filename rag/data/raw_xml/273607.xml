					</호내용>
				</호>
				<호>
					<호번호><![CDATA[2.]]></호번호>
					<호내용><![CDATA[2.  제4조제1항제3호의 증명서를 발급하는 경우(수동 발급의 경우 최초에 한한다)]]>
					</호내용>
				</호>
