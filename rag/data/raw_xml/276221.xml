				</항내용>
			</항>
			<항>
				<항번호><![CDATA[②]]></항번호>
				<항내용><![CDATA[② 대경과기원에 지식기반산업 및 과학기술에 관한 연구를 하게 하기 위하여 필요한 연구원을 둔다.]]>
				</항내용>
			</항>
			<항>
				<항번호><![CDATA[③]]></항번호>
				<항내용><![CDATA[③ 제1항에 따른 교원의 자격은 대통령령으로 정한다.]]>
				</항내용>
			</항>
