					</호내용>
				</호>
				<호>
					<호번호><![CDATA[3.]]></호번호>
					<호내용><![CDATA[3.  대안학교의 평가 및 운영 등에 관한 사항]]>
					</호내용>
				</호>
				<호>
					<호번호><![CDATA[4.]]></호번호>
					<호내용><![CDATA[4.  이 영에서 심의하도록 한 사항]]>
					</호내용>
				</호>
				<호>
					<호번호><![CDATA[5.]]></호번호>
					<호내용><![CDATA[5.  그 밖에 교육감이 필요하다고 인정하는 대안학교의 설립ㆍ운영에 관한 사항]]>
					</호내용>
				</호>
