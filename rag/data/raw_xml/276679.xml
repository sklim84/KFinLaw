			<항>
				<항번호><![CDATA[①]]></항번호>
				<항내용><![CDATA[① 국가는 의사상자의 구조행위로 인하여 의사상자의 물건이 멸실ㆍ훼손된 때에는 의상자 또는 의사자유족에게 그 손해액에 상당한 보상금을 지급한다. 다만, 다른 법률에 따라 손해배상을 받은 경우는 그러하지 아니하다.]]>
				</항내용>
			</항>
			<항>
				<항번호><![CDATA[②]]></항번호>
				<항내용><![CDATA[② 제1항의 보상금액은 그 물건의 교환가격 또는 필요한 수리비로 한다.]]>
				</항내용>
			</항>
			<항>
				<항번호><![CDATA[③]]></항번호>
				<항내용><![CDATA[③ 제1항의 보상금은 일시금으로 한다.]]>
				</항내용>
			</항>
			<항>
				<항번호><![CDATA[④]]></항번호>
				<항내용><![CDATA[④ 제1항의 보상금의 지급범위ㆍ 지급절차 등에 관하여 필요한 사항은 대통령령으로 정한다.]]>
				</항내용>
			</항>
