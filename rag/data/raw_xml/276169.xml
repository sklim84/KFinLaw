			<항>
				<항번호><![CDATA[①]]></항번호>
				<항내용><![CDATA[① 국립대학법인 인천대학교에 제12조 각 호에 따른 사항을 심의ㆍ의결하기 위하여 이사회를 둔다.]]>
				</항내용>
			</항>
			<항>
				<항번호><![CDATA[②]]></항번호>
				<항내용><![CDATA[② 이사회는 이사장을 포함한 이사로 구성한다.]]>
				</항내용>
			</항>
			<항>
				<항번호><![CDATA[③]]></항번호>
				<항내용><![CDATA[③ 이사장은 정관으로 정하는 바에 따라 이사 중에서 호선(互選)한다.]]>
				</항내용>
			</항>
			<항>
				<항번호><![CDATA[④]]></항번호>
				<항내용><![CDATA[④ 이사장은 필요하다고 인정할 경우에는 이사회를 소집할 수 있다. 다만, 총장 또는 재적이사 3분의 1 이상의 요청이 있거나, 감사가 제13조제4항에 따라 이사회의 소집을 요구하는 경우에는 이사회를 소집하여야 한다.]]>
				</항내용>
			</항>
			<항>
				<항번호><![CDATA[⑤]]></항번호>
				<항내용><![CDATA[⑤ 감사는 직무와 관련하여 필요한 경우 이사회에 출석하여 발언할 수 있다.]]>
				</항내용>
			</항>
			<항>
				<항번호><![CDATA[⑥]]></항번호>
				<항내용><![CDATA[⑥ 이사장 또는 이사는 자신과 특별한 이해관계가 있는 사안에 대하여는 의결권을 행사할 수 없다.]]>
				</항내용>
			</항>
			<항>
				<항번호><![CDATA[⑦]]></항번호>
				<항내용><![CDATA[⑦ 이사회는 정관에 특별한 규정이 없으면 재적이사 과반수의 출석으로 개의(開議)하고, 출석이사 과반수의 찬성으로 의결한다. 다만 제6항에 따라 의결권을 행사할 수 없는 이사의 수는 재적이사 수에서 제외한다. <개정 2021.3.23>]]>
				</항내용>
			</항>
			<항>
				<항번호><![CDATA[⑧]]></항번호>
				<항내용><![CDATA[⑧ 이사장이 궐위(闕位)되거나 불가피한 사유로 직무를 수행할 수 없을 경우에는 정관으로 정하는 바에 따라 직무를 대행한다.]]>
				</항내용>
			</항>
			<항>
				<항번호><![CDATA[⑨]]></항번호>
				<항내용><![CDATA[⑨ 그 밖에 이사회에 관하여 필요한 사항은 정관으로 정한다.]]>
				</항내용>
			</항>
