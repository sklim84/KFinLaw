			<항>
				<항번호><![CDATA[①]]></항번호>
				<항내용><![CDATA[① 대통령은 법 제5조제2항에 따라 임명 또는 위촉된 위원이 다음 각 호의 어느 하나에 해당하는 경우에는 해당 위원을 해임하거나 해촉(解囑)할 수 있다.]]>
				</항내용>
				<호>
					<호번호><![CDATA[1.]]></호번호>
					<호내용><![CDATA[1.  심신장애로 인하여 직무를 수행할 수 없게 된 경우]]>
					</호내용>
				</호>
				<호>
					<호번호><![CDATA[2.]]></호번호>
					<호내용><![CDATA[2.  직무와 관련된 비위사실이 있는 경우]]>
					</호내용>
				</호>
				<호>
					<호번호><![CDATA[3.]]></호번호>
					<호내용><![CDATA[3.  직무태만, 품위손상이나 그 밖의 사유로 인하여 위원으로 적합하지 아니하다고 인정되는 경우]]>
					</호내용>
				</호>
				<호>
					<호번호><![CDATA[4.]]></호번호>
					<호내용><![CDATA[4.  위원 스스로 직무를 수행하는 것이 곤란하다고 의사를 밝히는 경우]]>
					</호내용>
				</호>
			</항>
			<항>
				<항번호><![CDATA[②]]></항번호>
				<항내용><![CDATA[② 위원회 위원장은 전문위원이 제1항 각 호의 어느 하나에 해당하는 경우에는 해당 위원을 해임하거나 해촉할 수 있다.]]>
				</항내용>
			</항>
