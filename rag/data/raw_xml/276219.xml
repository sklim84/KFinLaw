			<조문내용><![CDATA[제2조(정의) 이 법에서 사용하는 용어의 뜻은 다음과 같다. <개정 2013.3.23, 2014.11.19, 2017.7.26, 2021.12.28, 2022.1.11, 2023.10.31, 2025.10.1>]]>
</조문내용>
			<항>
				<호>
					<호번호><![CDATA[1.]]></호번호>
					<호내용><![CDATA[1.  "뇌연구"란 뇌과학(腦科學), 뇌의약학(腦醫藥學), 뇌공학(腦工學), 뇌융합기술 및 이와 관련된 모든 분야에 대한 연구를 말한다.]]>
					</호내용>
				</호>
				<호>
					<호번호><![CDATA[2.]]></호번호>
					<호내용><![CDATA[2.  "뇌과학"이란 뇌의 신경생물학적 구조, 인지(認知), 사고, 언어심리 및 행동 등의 고등신경(高等神經) 정신활동에 대한 포괄적인 이해를 위한 기초학문을 말한다.]]>
					</호내용>
				</호>
				<호>
					<호번호><![CDATA[3.]]></호번호>
					<호내용><![CDATA[3.  "뇌의약학"이란 뇌의 구조 및 기능상의 결함과 뇌의 노화 등으로 인한 신체적ㆍ정신적 질환 및 장애의 원인 규명과 이의 치료, 예방 등에 관한 학문을 말한다.]]>
					</호내용>
				</호>
				<호>
					<호번호><![CDATA[4.]]></호번호>
					<호내용><![CDATA[4.  "뇌공학"이란 뇌의 고도의 지적 정보처리 구조와 기능을 이해하고 이의 공학적 응용을 위한 이론 및 기술에 관한 학문을 말한다.]]>
					</호내용>
				</호>
				<호>
					<호번호><![CDATA[4.]]></호번호>
					<호가지번호><![CDATA[2]]></호가지번호>
					<호내용><![CDATA[4의2.  "뇌연구자원"이란 뇌와 관련된 조직ㆍ세포ㆍ체액 등과 그로부터 분리한 산물, 임상정보 및 역학정보 등을 말한다.]]>
					</호내용>
				</호>
				<호>
					<호번호><![CDATA[4.]]></호번호>
					<호가지번호><![CDATA[3]]></호가지번호>
					<호내용><![CDATA[4의3.  "뇌은행"이란 뇌연구자원의 확보ㆍ보존ㆍ관리 및 활용 업무를 수행하는 기관으로서 제15조의2제1항에 따라 지정받은 기관을 말한다.]]>
					</호내용>
				</호>
				<호>
					<호번호><![CDATA[4.]]></호번호>
					<호가지번호><![CDATA[4]]></호가지번호>
					<호내용><![CDATA[4의4.  "뇌융합기술"이란 정보통신기술 또는 나노기술 등 다른 연구분야 기술을 뇌과학, 뇌의약학, 뇌공학 등에 융합하거나 복합한 기술로서 뇌질환의 진단, 뇌신경의 물리적ㆍ시각적ㆍ감각적 자극을 통한 뇌질환의 치료ㆍ예방, 뇌기능 활성화ㆍ활용 등에 적용되는 기술을 말한다.]]>
					</호내용>
				</호>
				<호>
					<호번호><![CDATA[5.]]></호번호>
					<호내용><![CDATA[5.  "관계 중앙행정기관"이란 과학기술정보통신부, 교육부, 산업통상부, 보건복지부 및 질병관리청을 말한다.]]>
					</호내용>
				</호>
				<호>
					<호번호><![CDATA[6.]]></호번호>
					<호내용><![CDATA[6.  "뇌산업"이란 뇌연구에 따른 기술이 적용된 제품을 개발ㆍ생산 또는 유통하거나 이와 관련된 서비스를 제공하는 산업을 말한다.]]>
					</호내용>
				</호>
