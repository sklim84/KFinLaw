			<조문내용><![CDATA[제2조(정의) 이 법에서 사용하는 용어의 뜻은 다음 각 호와 같다. <개정 2019.8.20>]]>
</조문내용>
			<항>
				<호>
					<호번호><![CDATA[1.]]></호번호>
					<호내용><![CDATA[1.  "폐교"란 「초ㆍ중등교육법」 제2조에 따른 학교로서 학생 수의 감소, 학교의 통폐합 등의 사유로 폐지된 공립학교를 말한다.]]>
					</호내용>
				</호>
				<호>
					<호번호><![CDATA[2.]]></호번호>
					<호내용><![CDATA[2.  "폐교재산"이란 폐교되기 전에 직접 또는 간접으로 그 학교의 교육활동에 사용되던 시설과 그 밖의 재산 중 공유재산을 말한다.]]>
					</호내용>
				</호>
				<호>
					<호번호><![CDATA[3.]]></호번호>
					<호내용><![CDATA[3.  "교육용시설"이란 유아, 청소년, 학생 및 주민 등의 학습을 주된 목적으로 하여 자연학습시설, 청소년수련시설, 도서관, 박물관, 야영장 등의 용도로 제공되는 시설을 말한다.]]>
					</호내용>
				</호>
				<호>
					<호번호><![CDATA[4.]]></호번호>
					<호내용><![CDATA[4.  "사회복지시설"이란 「사회복지사업법」 제2조에 따른 사회복지사업을 위한 용도로 제공되는 공간 및 시설을 말한다.]]>
					</호내용>
				</호>
				<호>
					<호번호><![CDATA[5.]]></호번호>
					<호내용><![CDATA[5.  "문화시설"이란 「문화예술진흥법」 제2조제1항제3호에 따른 시설을 말한다.]]>
					</호내용>
				</호>
				<호>
					<호번호><![CDATA[6.]]></호번호>
					<호내용><![CDATA[6.  "공공체육시설"이란 「체육시설의 설치ㆍ이용에 관한 법률」 제5조부터 제7조까지의 규정에 따른 시설을 말한다.]]>
					</호내용>
				</호>
				<호>
					<호번호><![CDATA[7.]]></호번호>
					<호내용><![CDATA[7.  "소득증대시설"이란 「농어촌정비법」 제2조제6호 또는 같은 조 제16호가목부터 다목까지의 규정에 따른 시설을 말한다.]]>
					</호내용>
				</호>
				<호>
					<호번호><![CDATA[8.]]></호번호>
					<호내용><![CDATA[8.  "귀농어ㆍ귀촌 지원시설"이란 「귀농어ㆍ귀촌 활성화 및 지원에 관한 법률」 제10조제4항제1호 또는 제2호의 사업을 위한 용도로 제공되는 시설로서 대통령령으로 정하는 시설을 말한다.]]>
					</호내용>
				</호>
