					<호내용><![CDATA[1.  "독서 문화"란 문자를 사용하여 표현된 것을 읽고 쓰는 활동을 중심으로 하여 이루어지는 정신적인 문화 활동과 그 문화적 소산을 말한다.]]>
					</호내용>
				</호>
				<호>
					<호번호><![CDATA[2.]]></호번호>
					<호내용><![CDATA[2.  "독서 자료"란 문자를 사용하여 표현된 도서ㆍ연속간행물 등 인쇄 자료, 시청각 자료, 전자 자료 및 장애인을 위한 특수 자료 등 독서 활동에 필요한 자료를 말한다.]]>
					</호내용>
				</호>
				<호>
					<호번호><![CDATA[3.]]></호번호>
					<호내용><![CDATA[3.  "독서소외인"이란 시각 장애, 노령화 등의 신체적 장애 또는 경제적ㆍ사회적ㆍ지리적 제약 등으로 독서 문화에서 소외되어 있거나 독서 자료의 이용이 어려운 자를 말한다.]]>
					</호내용>
				</호>
				<호>
					<호번호><![CDATA[4.]]></호번호>
					<호내용><![CDATA[4.  "학교"란 「초ㆍ중등교육법」에 따른 학교를 말한다.]]>
					</호내용>
				</호>
