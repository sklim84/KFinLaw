					</호내용>
				</호>
				<호>
					<호번호><![CDATA[2.]]></호번호>
					<호내용><![CDATA[2.  수입인지(국가기관에 내는 경우로 한정한다) 또는 수입증지(지방자치단체에 내는 경우로 한정한다)]]>
					</호내용>
