					<호번호><![CDATA[2.]]></호번호>
					<호내용><![CDATA[2.  기부자가 영수증 발급을 원하지 아니한 경우]]>
					</호내용>
				</호>
			</항>
			<항>
				<항번호><![CDATA[③]]></항번호>
				<항내용><![CDATA[③모집종사자는 기부금품의 모집을 중단하거나 끝낸 후 5일 이내에 모집자에게 접수명세와 접수금품을 인계하여야 한다.]]>
				</항내용>
